// === Enforcement Tiers ===
// DB:  → Prisma constructs: @unique, @@unique, @@index, @default, enum, required field, relation
// APP: → API/service logic, transactional writes, future SQL migrations
//
// Current Prisma schema for the Misión 1-99 application.
// packages/db owns its migration history and generated Prisma Client workflow.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7 keeps the connection URL in packages/db/prisma.config.ts.
}

enum ResponsibleUserStatus {
  ACTIVE
  INACTIVE
}

enum RefreshSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum FileStorageProvider {
  LOCAL
}

enum FileCategory {
  OUTING_MAIN_IMAGE
  OUTING_CROQUIS
  OUTING_PLAN
  POST_COVER_IMAGE
  POST_DOWNLOAD
  LANDING_HERO
  OTHER
}

enum FeaturedPostSlot {
  SLOT_1
  SLOT_2
  SLOT_3
}

model ResponsibleUser {
  // DB: Unique email (@unique), status enum tracks ACTIVE/INACTIVE, @@index([status])
  // APP: Login/content-creation guards must check status != INACTIVE
  id           String                @id @default(uuid())
  email        String                @unique
  displayName  String
  passwordHash String
  authVersion  Int                   @default(0)
  status       ResponsibleUserStatus @default(ACTIVE)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  refreshSessions RefreshSession[]
  authoredOutings Outing[]
  authoredPosts   Post[]
  authoredVerses  Verse[]
  verseRevisions  VerseRevision[]
  uploadedFiles   FileAsset[]

  @@index([status])
}

model RefreshSession {
  // DB: tokenHash @unique, status/expiresAt columns, @@index([userId, status]), @@index([expiresAt]), @@index([status, expiresAt])
  // APP: Hash-only storage; app layer handles revoke/rotate/expiry lifecycle
  id        String               @id @default(uuid())
  userId    String
  tokenHash String               @unique
  status    RefreshSessionStatus @default(ACTIVE)
  userAgent String?
  ipHash    String?
  expiresAt DateTime
  revokedAt DateTime?
  rotatedAt DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  user ResponsibleUser @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([expiresAt])
  @@index([status, expiresAt])
}

model FileAsset {
  // DB: fileSize, mimeType, extension metadata columns, @@index([category]), @@index([uploadedById]), @@index([createdAt])
  // APP: Upload MIME/size limits validated per FileCategory before insert
  id              String              @id @default(uuid())
  storageProvider FileStorageProvider @default(LOCAL)
  category        FileCategory
  originalFilename String
  mimeType        String
  extension       String?
  fileSize        Int
  storagePath     String
  url             String
  metadata        Json?
  thumbnailPath   String?
  uploadedById    String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime             @updatedAt

  uploadedBy ResponsibleUser? @relation(fields: [uploadedById], references: [id])

  outingMainImages Outing[]          @relation("OutingMainImage")
  outingCroquis    Outing[]          @relation("OutingCroquis")
  outingPlans      Outing[]          @relation("OutingPlan")
  postCoverImages  Post[]            @relation("PostCoverImage")
  postDownloads    PostDownload[]
  landingHeroes    LandingSettings[] @relation("LandingHero")

  @@index([category])
  @@index([uploadedById])
  @@index([createdAt])
}

model Outing {
  // DB: slug @unique, likesCount field, @@index([status, dateTime]), @@index([createdById])
  // APP: Outing.likesCount sync requires transactional writes on like/unlike
  id          String        @id @default(uuid())
  slug        String        @unique
  title       String
  dateTime    DateTime
  location    String
  description String
  status      ContentStatus @default(DRAFT)
  likesCount  Int           @default(0)
  mainImageId String?
  croquisId   String?
  planId      String?
  createdById String?
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  mainImage FileAsset?       @relation("OutingMainImage", fields: [mainImageId], references: [id])
  croquis   FileAsset?       @relation("OutingCroquis", fields: [croquisId], references: [id])
  plan      FileAsset?       @relation("OutingPlan", fields: [planId], references: [id])
  createdBy ResponsibleUser? @relation(fields: [createdById], references: [id])
  likes     OutingLike[]
  landing   LandingSettings?

  @@index([status, dateTime])
  @@index([createdById])
}

model OutingLike {
  // DB: @@unique([outingId, visitorHash]) dedupes; no identity columns stored
  // APP: Privacy-safe visitorHash derivation — salted hash from request/client signals at API layer; never raw IP or public identity
  id                 String   @id @default(uuid())
  outingId           String
  visitorHash        String
  fingerprintVersion Int      @default(1)
  createdAt          DateTime @default(now())

  outing Outing @relation(fields: [outingId], references: [id])

  @@unique([outingId, visitorHash])
  @@index([createdAt])
}

model Post {
  // DB: slug @unique, tags String[] @@index([tags], type: Gin), @@index([status, publishedAt]), @@index([createdById])
  // APP: Publish-readiness guard: status transition requires complete public fields
  id           String        @id @default(uuid())
  slug         String        @unique
  title        String
  description  String
  coverImageId String?
  content      String
  status       ContentStatus @default(DRAFT)
  tags         String[]      @default([])
  createdById  String?
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  coverImage   FileAsset?       @relation("PostCoverImage", fields: [coverImageId], references: [id])
  createdBy    ResponsibleUser? @relation(fields: [createdById], references: [id])
  downloads    PostDownload[]
  featuredSlot FeaturedPost?

  @@index([status, publishedAt])
  @@index([tags], type: Gin)
  @@index([createdById])
}

model FeaturedPost {
  // DB: FeaturedPostSlot enum (3 values) limits max featured posts; slot @unique, postId @unique
  //     featuredAt records when the post was featured for landing ordering (desc).
  //     Unfeature/archive/delete removes the row; active feature = row existence.
  id         String           @id @default(uuid())
  slot       FeaturedPostSlot @unique
  postId     String           @unique
  featuredAt DateTime         @default(now())
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  post Post @relation(fields: [postId], references: [id])

  @@index([featuredAt])
}

model PostDownload {
  // DB: @@unique([postId, fileId]) — one post per download file
  id        String   @id @default(uuid())
  postId    String
  fileId    String
  label     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  post Post      @relation(fields: [postId], references: [id])
  file FileAsset @relation(fields: [fileId], references: [id])

  @@unique([postId, fileId])
  @@index([postId, sortOrder])
}

model Verse {
  // DB: multiple verses per date allowed; publishedAt is the UTC instant of creation;
  //     date is the Peru business-day date derived from publishedAt (America/Lima).
  //     @@index([status, publishedAt]) for latest-remaining ordering; @@index([createdById]).
  id          String        @id @default(uuid())
  text        String
  reference   String
  date        DateTime
  publishedAt DateTime?
  status      ContentStatus @default(PUBLISHED)
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdBy ResponsibleUser? @relation(fields: [createdById], references: [id])
  revisions VerseRevision[]

  @@index([status, publishedAt])
  @@index([createdById])
}

model VerseRevision {
  // DB: @@index([verseId, changedAt]) — verse history/revision tracking
  id          String   @id @default(uuid())
  verseId     String
  text        String
  reference   String
  changedAt   DateTime @default(now())
  changedById String?

  verse     Verse            @relation(fields: [verseId], references: [id], onDelete: Cascade)
  changedBy ResponsibleUser? @relation(fields: [changedById], references: [id])

  @@index([verseId, changedAt])
}

model LandingSettings {
  // DB: featuredOutingId @unique — one featured outing
  // APP: Singleton enforcement: service keeps exactly one row with id = 1
  id               Int      @id @default(1)
  heroTitle        String?
  heroSubtitle     String?
  heroImageId      String?
  featuredOutingId String?  @unique
  mission          String?
  vision           String?
  description      String?
  featuredVideoUrl String?
  contactEmail     String?
  contactPhone     String?
  updatedAt        DateTime @updatedAt

  heroImage      FileAsset? @relation("LandingHero", fields: [heroImageId], references: [id])
  featuredOuting Outing?    @relation(fields: [featuredOutingId], references: [id])
}

// APP-tier invariants (see per-model // APP: labels for enforcement context):
// - FileAsset upload validation: allowed MIME types and max file size per FileCategory.
// - Content publish-readiness: complete public fields required before PUBLISHED status.
// - Outing.likesCount synchronization: transactional writes on like/unlike.
// - RefreshSession lifecycle: hash-only storage; rotate/revoke at application layer.
