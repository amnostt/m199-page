{
  "name": "m199-page",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Mision 1-99 monorepo for the Astro web app with React admin UI, NestJS API, and Prisma database package.",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "pnpm --filter @m199/web --filter @m199/api --parallel run dev",
    "dev:web": "pnpm --filter @m199/web run dev",
    "dev:api": "pnpm --filter @m199/api run dev",
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:reset": "tsx scripts/db-reset.ts",
    "db:status": "docker compose ps db",
    "db:seed": "pnpm --filter @m199/db run db:seed"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1"
  }
}
