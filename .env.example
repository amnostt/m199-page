# Local development environment contract for the m199-page workspace.
# Copy this file to `.env` before local development. Never commit `.env`.
#
# Prerequisite: Docker with Compose support must be installed.
# Start the local database with:
#   pnpm db:up
#
# The DATABASE_URL below matches the Compose service defaults and works
# out of the box for local/dev after `pnpm db:up`. PostgreSQL may need a
# short readiness wait before immediate Prisma or psql commands.
# Data persists in a named Docker volume until you run:
#   pnpm db:reset
# (which destroys and recreates the volume — local data is gone).

# API runtime env (apps/api) — validated at bootstrap before any DB access.
NODE_ENV=development
PORT=3000
API_ORIGIN="http://localhost:5173"

# JWT signing secret for local development. Replace with a long random value
# in real environments; this placeholder is not a production secret.
JWT_SECRET="local-development-jwt-secret-change-me"

# Salt used to hash anonymous visitor fingerprints for outing likes.
# Never store raw visitor identity; replace with a long random value in real environments.
VISITOR_HASH_SECRET="local-development-visitor-hash-secret-change-me"

# Database connection used by packages/db/prisma.config.ts (Prisma 7 env loading).
# This matches the compose.yml db service: user/password/database all "m199".
DATABASE_URL="postgresql://m199:m199@localhost:5432/m199?schema=public"

# Web app (apps/web) public env placeholders. No secrets here.
VITE_APP_TITLE="Mision 1-99"

# Astro SSR server (apps/web) — SERVER-ONLY base URL for the public landing
# payload fetch. No PUBLIC_ prefix, so Astro will NOT inline it in any client
# bundle. Must be an absolute http(s) URL; the trailing slash is normalized
# away while its allowed path is retained for `landing/public`. In local
# development this points
# at the NestJS API on PORT=3000. In production it points at the upstream
# the Caddy reverse proxy forwards /landing/public to (typically the Nest
# service on its private port). Validation lives in
# apps/web/src/lib/server/env.ts.
ASTRO_API_BASE_URL="http://localhost:3000"

# Astro SSR server listen port — bridged to the standalone Node runtime
# PORT by apps/web/server-entry.mjs (precedence: PORT > ASTRO_PORT > 4321).
# Caddy must reverse_proxy to this exact port for / and /_astro/*.
# Default 4321 is the Astro dev default; override per environment.
# ASTRO_PORT=4321
