# Local development environment contract for the m199-page workspace.
# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
# Prerequisite: PostgreSQL 16+ must be installed and running locally.
# Create the database before running migrations:
#   createdb m199

# API runtime env (apps/api) — validated at bootstrap before any DB access.
NODE_ENV=development
PORT=3000

# JWT signing secret for local development. Replace with a long random value
# in real environments; this placeholder is not a production secret.
JWT_SECRET="local-development-jwt-secret-change-me"

# Database connection used by packages/db/prisma.config.ts (Prisma 7 env loading).
# Angle-bracket placeholders are intentional — they are NOT real
# credentials. Replace <username> and <password> with your local
# PostgreSQL credentials when you copy this file to `.env`.
DATABASE_URL="postgresql://<username>:<password>@localhost:5432/m199?schema=public"

# Web app (apps/web) public env placeholders. No secrets here.
VITE_APP_TITLE="Mision 1-99"
